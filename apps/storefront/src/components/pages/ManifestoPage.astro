---
import { Image } from 'astro:assets';
import campaignPortrait from '../../assets/vexxx/campaign-portrait.png';
import vexxxMark from '../../assets/vexxx/vexxx-mark.png';
import { t } from '../../i18n';
import type { Locale } from '../../i18n/config';
import { routePath } from '../../i18n/routes';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
---

<article class="manifesto-page">
  <header class="manifesto-hero">
    <div class="manifesto-meta" data-reveal><span>{dict.manifesto.eyebrow}</span><span>{dict.manifesto.readTime}</span></div>
    <h1 class="display-title reveal-delay-1" data-reveal>{dict.manifesto.titleOne}<br /><span class="outline-text">{dict.manifesto.titleTwo}</span></h1>
    <p class="reveal-delay-2" data-reveal>{dict.manifesto.intro}</p>
  </header>
  <div class="manifesto-body">
    <div class="manifesto-sections">
      <section data-reveal="left"><span class="eyebrow">{dict.manifesto.sectionOneEyebrow}</span><p>{dict.manifesto.sectionOneBody}</p></section>
      <section data-reveal="left" class="reveal-delay-1"><span class="eyebrow">{dict.manifesto.sectionTwoEyebrow}</span><p>{dict.manifesto.sectionTwoBody}</p></section>
    </div>
    <figure data-reveal="right"><Image src={campaignPortrait} alt="" loading="lazy" /></figure>
  </div>
  <footer class="manifesto-end">
    <div><Image src={vexxxMark} alt="" width={58} height={58} /><span>{dict.manifesto.end}</span></div>
    <a class="button" href={routePath('products', locale)} data-cursor={dict.nav.cursorEnter}>{dict.manifesto.action} →</a>
  </footer>
</article>

<style>
  .manifesto-page { max-width: 78rem; margin: 0 auto; padding: clamp(8rem, 15vh, 11rem) var(--page-pad); }
  .manifesto-meta { display: flex; justify-content: space-between; gap: 1rem; color: var(--vx-dim); font-family: 'JetBrains Mono', monospace; font-size: 0.58rem; letter-spacing: 0.22em; }
  .manifesto-hero h1 { margin-top: clamp(3rem, 7vh, 5.5rem); font-size: clamp(4rem, 10vw, 11rem); }
  .manifesto-hero > p { max-width: 38rem; margin: clamp(2.5rem, 6vh, 4rem) 0 0; color: #b9bcbd; font-size: clamp(1rem, 1.5vw, 1.25rem); line-height: 1.8; }
  .manifesto-body { display: grid; grid-template-columns: 1fr 0.75fr; gap: clamp(3rem, 8vw, 8rem); margin-top: clamp(5rem, 11vh, 9rem); }
  .manifesto-sections { display: grid; align-content: center; gap: 3rem; }
  .manifesto-sections p { margin: 1rem 0 0; color: #b9bcbd; line-height: 1.85; }
  .manifesto-body figure { min-height: 40rem; margin: 0; overflow: hidden; border: 1px solid rgb(232 230 225 / 8%); }
  .manifesto-body figure img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(0.65); }
  .manifesto-end { display: flex; align-items: center; justify-content: space-between; gap: 2rem; margin-top: clamp(5rem, 10vh, 8rem); padding-top: 2rem; border-top: 1px solid var(--vx-line); }
  .manifesto-end > div { display: flex; align-items: center; gap: 1rem; }
  .manifesto-end img { mix-blend-mode: screen; }
  .manifesto-end span { max-width: 18rem; color: var(--vx-dim); font-family: 'JetBrains Mono', monospace; font-size: 0.54rem; letter-spacing: 0.18em; line-height: 1.8; white-space: pre-line; }

  @media (max-width: 750px) {
    .manifesto-body { grid-template-columns: 1fr; }
    .manifesto-body figure { min-height: 34rem; }
    .manifesto-end { align-items: flex-start; flex-direction: column; }
  }
</style>
