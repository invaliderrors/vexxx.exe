---
import { Image } from 'astro:assets';
import campaignGroup from '../../assets/vexxx/campaign-group.png';
import { t } from '../../i18n';
import type { Locale } from '../../i18n/config';
import { routePath } from '../../i18n/routes';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
---

<section class="archive-page">
  <div class="eyebrow" data-reveal>{dict.archive.eyebrow}</div>
  <h1 class="display-title reveal-delay-1" data-reveal>{dict.archive.heading}</h1>
  <div class="archive-list">
    <div class="archive-row archive-row--encrypted" data-reveal>
      <div><span>002</span><strong>{dict.archive.drop002}</strong></div>
      <em>{dict.archive.encrypted}</em>
    </div>
    <a class="archive-row reveal-delay-05" href={routePath('products', locale)} data-reveal data-cursor={dict.nav.cursorEnter}>
      <div><span>001</span><strong>{dict.archive.drop001} →</strong></div>
      <em>{dict.archive.active}</em>
    </a>
    <div class="archive-row archive-row--retired reveal-delay-1" data-reveal>
      <div><span>000</span><strong>{dict.archive.drop000}</strong></div>
      <em>{dict.archive.retired}</em>
    </div>
  </div>
  <figure class="archive-image" data-reveal>
    <Image src={campaignGroup} alt={dict.archive.footage} loading="lazy" widths={[768, 1280, 1920]} sizes="100vw" />
    <figcaption>{dict.archive.footage}</figcaption>
  </figure>
</section>

<style>
  .archive-page { max-width: 82rem; min-height: 100vh; margin: 0 auto; padding: clamp(8rem, 15vh, 11rem) var(--page-pad); }
  .archive-page h1 { margin: 1rem 0 clamp(3rem, 7vh, 5rem); font-size: clamp(4rem, 9vw, 9rem); }
  .archive-list { border-top: 1px solid rgb(232 230 225 / 12%); }
  .archive-row { display: flex; align-items: baseline; justify-content: space-between; gap: 2rem; padding: clamp(1.7rem, 4vh, 2.8rem) 0; border-bottom: 1px solid rgb(232 230 225 / 12%); }
  .archive-row > div { display: flex; align-items: baseline; gap: 1.4rem; }
  .archive-row span, .archive-row em { font-family: 'JetBrains Mono', monospace; font-size: 0.58rem; letter-spacing: 0.16em; font-style: normal; }
  .archive-row span { color: var(--vx-accent); }
  .archive-row em { color: #7a7d80; text-align: right; }
  .archive-row strong { font-family: 'Anton', sans-serif; font-size: clamp(2.4rem, 5.5vw, 5.5rem); font-weight: 400; line-height: 1; }
  a.archive-row:hover strong { color: var(--vx-accent); }
  .archive-row--encrypted strong, .archive-row--retired strong, .archive-row--retired span, .archive-row--retired em { color: var(--vx-dim); }
  .archive-row--retired strong { text-decoration: line-through 3px; }
  .archive-image { position: relative; height: min(55vh, 35rem); margin: clamp(3rem, 7vh, 5rem) 0 0; overflow: hidden; border: 1px solid rgb(232 230 225 / 7%); }
  .archive-image img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(1) contrast(1.2); }
  .archive-image figcaption { position: absolute; bottom: 1rem; left: 1rem; padding: 0.45rem 0.65rem; background: rgb(5 5 5 / 78%); font-family: 'JetBrains Mono', monospace; font-size: 0.52rem; letter-spacing: 0.16em; }

  @media (max-width: 650px) {
    .archive-row { align-items: flex-start; flex-direction: column; gap: 0.8rem; }
    .archive-row em { text-align: left; }
  }
</style>
