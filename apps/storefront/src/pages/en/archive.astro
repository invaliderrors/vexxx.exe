---
import ArchivePage from '../../components/pages/ArchivePage.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n';
import { routeAlternates, routePath } from '../../i18n/routes';

const locale = 'en' as const;
const dict = t(locale);
---

<BaseLayout locale={locale} title={dict.archive.metaTitle} description={dict.archive.metaDescription} path={routePath('archive', locale)} alternates={routeAlternates('archive')}>
  <ArchivePage locale={locale} />
</BaseLayout>
