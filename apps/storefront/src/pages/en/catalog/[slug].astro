---
import { getImage } from 'astro:assets';
import JsonLd from '../../../components/seo/JsonLd.astro';
import ProductDetail from '../../../components/catalog/ProductDetail.astro';
import { productImage } from '../../../components/catalog/product-images';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { t } from '../../../i18n';
import { productPath, routePath } from '../../../i18n/routes';
import { getCatalog, type Product } from '../../../lib/catalog';
import {
  breadcrumbJsonLd,
  productJsonLd,
  schemaAvailability,
} from '../../../lib/seo/jsonld';
import { canonicalUrl } from '../../../lib/seo/meta';

export async function getStaticPaths() {
  const products = await getCatalog().getPublishedProducts();
  return products.map((product) => ({
    params: { slug: product.slug.en },
    props: { product },
  }));
}

interface Props {
  product: Product;
}

const { product }: Props = Astro.props;
const locale = 'en' as const;
const dict = t(locale);
const site = Astro.site;
if (!site) {
  throw new Error('SEO: `site` must be configured in astro.config.mjs');
}

const path = productPath(locale, product.slug[locale]);
const alternates = {
  es: productPath('es', product.slug.es),
  en: productPath('en', product.slug.en),
};
const url = canonicalUrl(site, path);
const socialImage = await getImage({
  src: productImage(product.sku),
  format: 'jpeg',
  width: 1200,
});
const socialImageUrl = new URL(socialImage.src, site).toString();
const absoluteImages = [
  socialImageUrl,
  ...product.images.map((image) =>
    image.src.startsWith('/') ? new URL(image.src, site).toString() : image.src,
  ),
];
const related = (await getCatalog().getPublishedProducts())
  .filter((item) => item.id !== product.id)
  .slice(0, 3);
---

<BaseLayout
  locale={locale}
  title={product.name[locale]}
  description={product.description[locale]}
  path={path}
  alternates={alternates}
  ogType="product"
  image={absoluteImages[0]}
>
  <JsonLd
    slot="head"
    data={breadcrumbJsonLd([
      {
        name: dict.product.breadcrumbHome,
        url: canonicalUrl(site, routePath('home', locale)),
      },
      {
        name: dict.product.breadcrumbProducts,
        url: canonicalUrl(site, routePath('products', locale)),
      },
      { name: product.name[locale], url },
    ])}
  />
  <JsonLd
    slot="head"
    data={productJsonLd({
      name: product.name[locale],
      description: product.description[locale],
      url,
      sku: product.sku,
      images: absoluteImages,
      price: product.price,
      availability: schemaAvailability(product.availability),
    })}
  />
  <ProductDetail product={product} related={related} locale={locale} />
</BaseLayout>
