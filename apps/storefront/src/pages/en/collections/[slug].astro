---
import JsonLd from '../../../components/seo/JsonLd.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { t } from '../../../i18n';
import { collectionPath, productPath, routePath } from '../../../i18n/routes';
import {
  getCatalog,
  type Collection,
  type Product,
} from '../../../lib/catalog';
import { formatPrice } from '../../../lib/format';
import { breadcrumbJsonLd } from '../../../lib/seo/jsonld';
import { canonicalUrl } from '../../../lib/seo/meta';

export async function getStaticPaths() {
  const catalog = getCatalog();
  const collections = await catalog.getPublishedCollections();
  return Promise.all(
    collections.map(async (collection) => ({
      params: { slug: collection.slug.en },
      props: {
        collection,
        products: await catalog.getProductsByCollection(collection.id),
      },
    })),
  );
}

interface Props {
  collection: Collection;
  products: readonly Product[];
}

const { collection, products }: Props = Astro.props;
const locale = 'en' as const;
const dict = t(locale);
const site = Astro.site;
if (!site) {
  throw new Error('SEO: `site` must be configured in astro.config.mjs');
}

const path = collectionPath(locale, collection.slug[locale]);
const alternates = {
  es: collectionPath('es', collection.slug.es),
  en: collectionPath('en', collection.slug.en),
};
---

<BaseLayout
  locale={locale}
  title={collection.name[locale]}
  description={collection.description[locale]}
  path={path}
  alternates={alternates}
>
  <JsonLd
    slot="head"
    data={breadcrumbJsonLd([
      {
        name: dict.product.breadcrumbHome,
        url: canonicalUrl(site, routePath('home', locale)),
      },
      {
        name: dict.collections.heading,
        url: canonicalUrl(site, routePath('collections', locale)),
      },
      { name: collection.name[locale], url: canonicalUrl(site, path) },
    ])}
  />
  <h1>{collection.name[locale]}</h1>
  <p>{collection.description[locale]}</p>
  {
    products.length === 0 ? (
      <p>{dict.products.empty}</p>
    ) : (
      <ul>
        {products.map((product) => (
          <li>
            <a href={productPath(locale, product.slug[locale])}>
              {product.name[locale]}
            </a>
            <data value={String(product.price.amount)}>
              {formatPrice(product.price, locale)}
            </data>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
