---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocumentPage from '../../components/pages/DocumentPage.astro';
import { t } from '../../i18n';
import { routeAlternates, routePath } from '../../i18n/routes';

const locale = 'en' as const;
const dict = t(locale);
---

<BaseLayout
  locale={locale}
  title={dict.legal.privacy.metaTitle}
  description={dict.legal.privacy.metaDescription}
  path={routePath('privacy', locale)}
  alternates={routeAlternates('privacy')}
>
  <DocumentPage eyebrow={dict.legal.eyebrow} heading={dict.legal.privacy.heading} body={dict.legal.privacy.body} status={dict.legal.pending} />
</BaseLayout>
