---
import BaseLayout from '../layouts/BaseLayout.astro';
import DocumentPage from '../components/pages/DocumentPage.astro';
import { t } from '../i18n';
import { routeAlternates, routePath } from '../i18n/routes';

const locale = 'es' as const;
const dict = t(locale);
---

<BaseLayout
  locale={locale}
  title={dict.legal.shipping.metaTitle}
  description={dict.legal.shipping.metaDescription}
  path={routePath('shipping', locale)}
  alternates={routeAlternates('shipping')}
  noindex
>
  <DocumentPage eyebrow={dict.legal.eyebrow} heading={dict.legal.shipping.heading} body={dict.legal.shipping.body} status={dict.legal.pending} />
</BaseLayout>
