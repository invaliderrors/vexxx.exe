---
import ManifestoPage from '../components/pages/ManifestoPage.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { t } from '../i18n';
import { routeAlternates, routePath } from '../i18n/routes';

const locale = 'es' as const;
const dict = t(locale);
---

<BaseLayout locale={locale} title={dict.manifesto.metaTitle} description={dict.manifesto.metaDescription} path={routePath('manifesto', locale)} alternates={routeAlternates('manifesto')}>
  <ManifestoPage locale={locale} />
</BaseLayout>
