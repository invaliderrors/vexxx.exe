---
import BaseLayout from '../layouts/BaseLayout.astro';
import DocumentPage from '../components/pages/DocumentPage.astro';
import { t } from '../i18n';
import { routePath } from '../i18n/routes';

const locale = 'es' as const;
const dict = t(locale);
---

<BaseLayout
  locale={locale}
  title={dict.notFound.metaTitle}
  description={dict.notFound.body}
  path="/404"
  alternates={{ es: '/404', en: '/404' }}
  noindex={true}
>
  <DocumentPage eyebrow={dict.brand.systemName} heading={dict.notFound.heading} body={dict.notFound.body} />
  <a class="not-found-action button" href={routePath('home', locale)}>{dict.notFound.backHome} →</a>
</BaseLayout>

<style>
  .not-found-action { position: relative; z-index: 2; margin: -9rem var(--page-pad) 8rem; }
</style>
