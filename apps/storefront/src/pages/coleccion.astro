---
import CollectionPage from '../components/pages/CollectionPage.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { t } from '../i18n';
import { routeAlternates, routePath } from '../i18n/routes';
import { breadcrumbJsonLd } from '../lib/seo/jsonld';
import { canonicalUrl } from '../lib/seo/meta';

const locale = 'es' as const;
const dict = t(locale);
const site = Astro.site;
if (!site) {
  throw new Error('SEO: `site` must be configured in astro.config.mjs');
}
---

<BaseLayout
  locale={locale}
  title={dict.collectionPage.metaTitle}
  description={dict.collectionPage.metaDescription}
  path={routePath('collection', locale)}
  alternates={routeAlternates('collection')}
>
  <JsonLd
    slot="head"
    data={breadcrumbJsonLd([
      {
        name: dict.product.breadcrumbHome,
        url: canonicalUrl(site, routePath('home', locale)),
      },
      {
        name: dict.collectionPage.heading,
        url: canonicalUrl(site, routePath('collection', locale)),
      },
    ])}
  />
  <CollectionPage locale={locale} />
</BaseLayout>
