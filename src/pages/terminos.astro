---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t } from '../i18n';
import { routeAlternates, routePath } from '../i18n/routes';

const locale = 'es' as const;
const dict = t(locale);
---

<BaseLayout
  locale={locale}
  title={dict.legal.terms.metaTitle}
  description={dict.legal.terms.metaDescription}
  path={routePath('terms', locale)}
  alternates={routeAlternates('terms')}
>
  <h1>{dict.legal.terms.heading}</h1>
  <p>{dict.legal.terms.body}</p>
</BaseLayout>
